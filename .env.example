# ============================================================
# onvifNVR – Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ── Docker image tag (used by docker-compose) ──────────────
IMAGE_TAG=latest
GITHUB_REPOSITORY=masterdeepak15/onvifnvr

# ── Ports ──────────────────────────────────────────────────
API_PORT=5000
UI_PORT=3000

# ── Database ───────────────────────────────────────────────
# SQLite (default – no extra container needed)
DATABASE_PROVIDER=SQLite
SQLITE_CONNECTION=Data Source=/var/nvr/data/nvr.db

# SQL Server (set DATABASE_PROVIDER=SqlServer and use --profile sqlserver)
# DATABASE_PROVIDER=SqlServer
DB_HOST=sqlserver
DB_NAME=NvrDb
DB_USER=sa
DB_PASSWORD=NvrP@ss2024!

# ── JWT ────────────────────────────────────────────────────
# IMPORTANT: Change this secret before deploying to production!
JWT_SECRET=NVR-SuperSecretKey-ChangeInProduction-AtLeast32Characters!
JWT_ISSUER=NVR.API
JWT_AUDIENCE=NVR.Client
JWT_EXPIRY_HOURS=1

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGIN_0=http://localhost:3000
CORS_ORIGIN_1=http://localhost:8080
CORS_ORIGIN_2=

# ── Frontend ───────────────────────────────────────────────
# Leave empty when UI is served by nginx (proxy mode – recommended).
# Set to http://your-api-host:5000 only when UI is on a separate server.
VITE_API_URL=

# ── Recording & Storage ────────────────────────────────────
# Override with a host path to store recordings on a NAS or large disk.
# NVR_DATA_PATH=/mnt/nvr/data
# RECORDINGS_PATH=/mnt/nvr/recordings
# TEMP_CHUNKS_PATH=/tmp/nvr_chunks
CHUNK_DURATION_SECONDS=60
DEFAULT_BITRATE_KBPS=2000
# HW_ACCEL options: none | vaapi | nvenc | videotoolbox
HW_ACCEL=none

# ── Streaming ──────────────────────────────────────────────
MAX_CAMERAS=64
DEFAULT_FPS=15
DEFAULT_WIDTH=1280
DEFAULT_HEIGHT=720
